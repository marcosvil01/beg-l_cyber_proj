{
  "manifest_version": 3,
  "name": "CyberHub Security Shield",
  "version": "1.0",
  "description": "A basic security extension for CyberHub training.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
